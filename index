<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portfolio Manager</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap');
:root{
  --bg:#f4f1ea;--surface:#fffdf7;--surface2:#ede9df;--surface3:#e4e0d5;
  --border:#d4cfc2;--border2:#b8b2a2;--text:#1c1a15;--muted:#7a7468;
  --accent:#2a5c3f;--gold:#9a7a1a;--blue:#1a3a6b;--purple:#5a1a8b;
  --green:#1e6b3a;--yellow:#9a6b00;--red:#8b1a1a;
  --green-bg:#eaf4ed;--yellow-bg:#fdf6e3;--red-bg:#fdeaea;
  --blue-bg:#e8eef8;--purple-bg:#f0eaf8;--shadow:0 2px 12px rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'IBM Plex Sans',sans-serif;min-height:100vh;
  background-image:repeating-linear-gradient(0deg,transparent,transparent 31px,rgba(0,0,0,.015) 31px,rgba(0,0,0,.015) 32px);}
.app-header{background:var(--text);color:var(--bg);padding:1.1rem 2rem;display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:.5rem;}
.app-header h1{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;letter-spacing:.01em;}
.app-header h1 em{color:#c8b882;font-style:normal;}
.header-meta{font-size:.68rem;color:#7a7060;font-family:'IBM Plex Mono',monospace;}
.signal-bar{background:var(--surface2);border-bottom:1px solid var(--border);padding:.65rem 2rem;display:flex;align-items:center;gap:1.2rem;flex-wrap:wrap;}
.signal-bar-label{font-family:'IBM Plex Mono',monospace;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);white-space:nowrap;}
.signal-btns{display:flex;gap:.3rem;}
.sig-btn{background:var(--surface);border:1px solid var(--border);border-radius:5px;font-family:'IBM Plex Mono',monospace;font-size:.72rem;padding:.3rem .9rem;cursor:pointer;color:var(--muted);transition:all .15s;}
.sig-btn:hover{border-color:var(--accent);color:var(--accent);}
.sig-btn.green.active{background:var(--green-bg);border-color:var(--green);color:var(--green);font-weight:500;}
.sig-btn.yellow.active{background:var(--yellow-bg);border-color:var(--yellow);color:var(--yellow);font-weight:500;}
.sig-btn.red.active{background:var(--red-bg);border-color:var(--red);color:var(--red);font-weight:500;}
.signal-note{font-size:.68rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;}
.tab-bar{background:var(--text);display:flex;padding:0 2rem;gap:0;border-bottom:2px solid #2a2a2a;}
.tab-btn{background:transparent;border:none;color:#6a6258;font-family:'IBM Plex Mono',monospace;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;padding:.7rem 1.3rem;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .15s,border-color .15s;}
.tab-btn:hover{color:#c8b882;}
.tab-btn.active{color:#f4f1ea;border-bottom-color:#c8b882;}
.tab-pane{display:none;padding:1.8rem 2rem;max-width:1120px;margin:0 auto;}
.tab-pane.active{display:block;}
.sec-head{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;margin-bottom:1.1rem;padding-bottom:.5rem;border-bottom:1px solid var(--border);display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:.4rem;}
.sec-head small{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--muted);font-weight:400;}
.summary-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.9rem;margin-bottom:1.5rem;}
.sum-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:.95rem 1.1rem;box-shadow:var(--shadow);}
.sum-card .sc-label{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem;}
.sum-card .sc-val{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;line-height:1;}
.sum-card .sc-sub{font-size:.67rem;color:var(--muted);margin-top:.18rem;}
.sc-val.green{color:var(--green);}.sc-val.yellow{color:var(--yellow);}.sc-val.red{color:var(--red);}.sc-val.blue{color:var(--blue);}.sc-val.accent{color:var(--accent);}
.tbl-wrap{overflow-x:auto;margin-bottom:1.3rem;}
.htable{width:100%;border-collapse:collapse;font-size:.8rem;}
.htable th{text-align:left;font-family:'IBM Plex Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:.45rem .7rem;border-bottom:2px solid var(--border2);white-space:nowrap;}
.htable td{padding:.58rem .7rem;border-bottom:1px solid var(--border);vertical-align:middle;}
.htable tbody tr:hover td{background:var(--surface2);}
.htable .right{text-align:right;}
.tc{font-family:'IBM Plex Mono',monospace;font-weight:500;font-size:.83rem;color:var(--accent);}
.tn{color:var(--muted);font-size:.76rem;max-width:170px;}
.tag{display:inline-block;padding:2px 7px;border-radius:3px;font-size:.6rem;font-family:'IBM Plex Mono',monospace;font-weight:500;letter-spacing:.04em;white-space:nowrap;}
.tag-ira{background:var(--blue-bg);color:var(--blue);border:1px solid #b8c8e8;}
.tag-roth{background:var(--green-bg);color:var(--green);border:1px solid #b8d8c0;}
.tag-brok{background:var(--yellow-bg);color:var(--yellow);border:1px solid #ddd090;}
.tag-hsa{background:var(--purple-bg);color:var(--purple);border:1px solid #d0b8e8;}
.yld{font-family:'IBM Plex Mono',monospace;color:var(--green);font-size:.8rem;}
.er{font-family:'IBM Plex Mono',monospace;color:var(--muted);font-size:.74rem;}
.alloc-inp{width:60px;background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:3px 6px;font-family:'IBM Plex Mono',monospace;font-size:.78rem;color:var(--text);text-align:right;}
.alloc-inp:focus{outline:none;border-color:var(--accent);}
.mono{font-family:'IBM Plex Mono',monospace;}
.alloc-bar-row{margin-bottom:1.2rem;}
.alloc-bar-labels{display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--muted);margin-bottom:.3rem;}
.alloc-bar{height:7px;background:var(--surface2);border-radius:4px;overflow:hidden;border:1px solid var(--border);}
.alloc-bar-fill{height:100%;border-radius:4px;background:var(--accent);transition:width .4s;}
.alloc-bar-fill.over{background:var(--red);}
.info-box{background:var(--blue-bg);border:1px solid #b8c8e8;border-radius:7px;padding:.85rem 1.1rem;font-size:.76rem;line-height:1.6;color:var(--blue);margin-bottom:1.1rem;}
.warn-box{background:var(--yellow-bg);border:1px solid #ddd090;border-radius:7px;padding:.85rem 1.1rem;font-size:.76rem;line-height:1.6;color:var(--yellow);margin-bottom:1.1rem;}
.btn{display:inline-flex;align-items:center;gap:.4rem;border-radius:6px;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:.72rem;letter-spacing:.04em;padding:.52rem 1.1rem;transition:opacity .15s,transform .1s;border:none;}
.btn:active{transform:scale(.97);}
.btn-primary{background:var(--accent);color:#fff;}.btn-primary:hover{opacity:.87;}
.btn-outline{background:transparent;color:var(--accent);border:1px solid var(--accent);}.btn-outline:hover{background:var(--green-bg);}
.btn-row{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.9rem;}
.accounts-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:1.1rem;margin-bottom:1.5rem;}
.acct-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.2rem 1.4rem;border-top:3px solid var(--border);box-shadow:var(--shadow);}
.acct-card.ira{border-top-color:var(--blue);}.acct-card.roth{border-top-color:var(--green);}.acct-card.brok{border-top-color:var(--yellow);}.acct-card.hsa{border-top-color:var(--purple);}
.acct-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:600;margin-bottom:.8rem;}
.acct-field{margin-bottom:.55rem;}
.acct-field label{display:block;font-size:.6rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.2rem;}
.acct-field input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:.38rem .65rem;font-family:'IBM Plex Mono',monospace;font-size:.85rem;color:var(--text);outline:none;transition:border-color .2s;}
.acct-field input:focus{border-color:var(--accent);}
.acct-tickers{margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border);}
.acct-tickers .tl{font-size:.58rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.35rem;}
.ticker-pills{display:flex;flex-wrap:wrap;gap:3px;}
.ticker-pill{font-family:'IBM Plex Mono',monospace;font-size:.63rem;padding:2px 6px;border-radius:3px;background:var(--surface2);border:1px solid var(--border);color:var(--accent);}
.dca-controls{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:1.1rem 1.4rem;margin-bottom:1.2rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.9rem;align-items:end;}
.dc-head{grid-column:1/-1;font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.dc-field label{display:block;font-size:.6rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.22rem;}
.dc-field input,.dc-field select{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:.38rem .65rem;font-family:'IBM Plex Mono',monospace;font-size:.83rem;color:var(--text);outline:none;transition:border-color .2s;-webkit-appearance:none;}
.dc-field input:focus,.dc-field select:focus{border-color:var(--accent);}
.dca-table{width:100%;border-collapse:collapse;font-size:.78rem;margin-bottom:1rem;}
.dca-table th{font-family:'IBM Plex Mono',monospace;font-size:.57rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:.4rem .65rem;border-bottom:2px solid var(--border2);text-align:left;}
.dca-table td{padding:.5rem .65rem;border-bottom:1px solid var(--border);}
.dca-table tbody tr:hover td{background:var(--surface2);}
.dca-amt{font-family:'IBM Plex Mono',monospace;font-weight:500;color:var(--accent);}
.dca-rat{font-size:.68rem;color:var(--muted);line-height:1.4;}
.pri-badge{display:inline-block;padding:2px 7px;border-radius:3px;font-size:.59rem;font-family:'IBM Plex Mono',monospace;}
.pri-green{background:var(--green-bg);color:var(--green);}.pri-yellow{background:var(--yellow-bg);color:var(--yellow);}.pri-red{background:var(--red-bg);color:var(--red);}
.proj-controls{display:flex;flex-wrap:wrap;gap:.7rem;margin-bottom:1.2rem;align-items:center;}
.proj-btn{background:var(--surface);border:1px solid var(--border);border-radius:5px;padding:.38rem .95rem;font-family:'IBM Plex Mono',monospace;font-size:.7rem;cursor:pointer;color:var(--muted);transition:all .15s;}
.proj-btn:hover{border-color:var(--accent);color:var(--accent);}
.proj-btn.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.proj-lbl{font-family:'IBM Plex Mono',monospace;font-size:.62rem;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-right:.2rem;}
.chart-wrap{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.3rem 1.4rem;margin-bottom:1.2rem;box-shadow:var(--shadow);}
.chart-title{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:600;color:var(--muted);margin-bottom:.9rem;display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:.4rem;}
.chart-title small{font-family:'IBM Plex Mono',monospace;font-size:.6rem;font-weight:400;}
canvas{width:100%!important;}
.proj-legend{display:flex;gap:1.2rem;margin-top:.7rem;flex-wrap:wrap;}
.leg-item{display:flex;align-items:center;gap:.35rem;font-size:.68rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;}
.leg-dot{width:18px;height:3px;border-radius:2px;flex-shrink:0;}
.longevity-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:1.2rem 1.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;box-shadow:var(--shadow);}
.lon-item .lon-label{font-size:.58rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.18rem;}
.lon-val{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;}
.lon-val.good{color:var(--green);}.lon-val.warn{color:var(--yellow);}.lon-val.bad{color:var(--red);}
.rmd-card{background:var(--yellow-bg);border:1px solid #ddd090;border-radius:8px;padding:1rem 1.3rem;margin-top:1.2rem;font-size:.76rem;line-height:1.65;color:var(--yellow);}
.disclaimer{font-size:.66rem;color:var(--muted);line-height:1.55;border-top:1px solid var(--border);padding-top:.85rem;margin-top:1rem;}
@media(max-width:650px){.tab-pane{padding:1.2rem 1rem;}.app-header,.signal-bar{padding:.9rem 1rem;}.tab-bar{padding:0 .5rem;overflow-x:auto;}.tab-btn{padding:.6rem .8rem;font-size:.62rem;}}
</style>
</head>
<body>
<div class="app-header">
  <h1>Portfolio <em>Manager</em></h1>
  <span class="header-meta">Conservative Income &middot; Age 69 &middot; Horizon to 95</span>
</div>
<div class="signal-bar">
  <span class="signal-bar-label">Market Signal (Tool 1):</span>
  <div class="signal-btns">
    <button class="sig-btn green"  id="sig-green"  onclick="setSignal('green')">&#x1F7E2; Full DCA</button>
    <button class="sig-btn yellow" id="sig-yellow" onclick="setSignal('yellow')">&#x1F7E1; Half DCA</button>
    <button class="sig-btn red"    id="sig-red"    onclick="setSignal('red')">&#x1F534; Hold Cash</button>
  </div>
  <span class="signal-note" id="signal-note">Select today's signal from Market Signal Tool 1 before viewing DCA Plan</span>
</div>
<div class="tab-bar">
  <button class="tab-btn active" onclick="showTab('holdings',this)">01 Holdings</button>
  <button class="tab-btn"       onclick="showTab('accounts',this)">02 Accounts</button>
  <button class="tab-btn"       onclick="showTab('dca',this)">03 DCA Plan</button>
  <button class="tab-btn"       onclick="showTab('projection',this)">04 Projection</button>
</div>

<!-- TAB 1: HOLDINGS -->
<div class="tab-pane active" id="tab-holdings">
  <div class="sec-head">My Holdings<small id="alloc-label">Total: 0%</small></div>
  <div class="alloc-bar-row">
    <div class="alloc-bar-labels"><span>Allocation used</span><span id="alloc-pct-text">0 / 100%</span></div>
    <div class="alloc-bar"><div class="alloc-bar-fill" id="alloc-bar-fill" style="width:0%"></div></div>
  </div>
  <div class="summary-row">
    <div class="sum-card"><div class="sc-label">Portfolio Value</div><div class="sc-val blue" id="sv-port">$0</div><div class="sc-sub">All accounts combined</div></div>
    <div class="sum-card"><div class="sc-label">Annual Income</div><div class="sc-val" id="sv-income">$0</div><div class="sc-sub">Dividends + interest</div></div>
    <div class="sum-card"><div class="sc-label">Income Target (4%)</div><div class="sc-val" id="sv-target">$0</div><div class="sc-sub">Need to cover expenses</div></div>
    <div class="sum-card"><div class="sc-label">Coverage</div><div class="sc-val" id="sv-cov">0%</div><div class="sc-sub">Income vs target</div></div>
    <div class="sum-card"><div class="sc-label">Blended Yield</div><div class="sc-val" id="sv-yield">0%</div><div class="sc-sub">Weighted avg yield</div></div>
    <div class="sum-card"><div class="sc-label">Blended ER</div><div class="sc-val" id="sv-er">0%</div><div class="sc-sub">Weighted avg cost</div></div>
  </div>
  <div class="tbl-wrap">
    <table class="htable">
      <thead><tr><th>Ticker</th><th>Name</th><th>Category</th><th>Best Account</th><th>Income Type</th><th class="right">Yield%</th><th class="right">ER%</th><th class="right">Alloc%</th><th class="right">$ Value</th><th class="right">Ann. Income</th></tr></thead>
      <tbody id="htable-body"></tbody>
    </table>
  </div>
  <div class="info-box">
    <strong>Tax placement rules used above:</strong> Ordinary income funds (SGOV, VTIP, BSV, JEPI, QQQI, PFF) belong in IRA &mdash; income compounds without annual tax drag. Qualified dividend funds (SCHD, SPDW, XLE) are tax-efficient in Brokerage &mdash; taxed at 0&ndash;15% and eligible for foreign tax credits (SPDW). VTI grows tax-free forever in Roth &mdash; the most powerful placement over 26 years. Gold (IAU) avoids the 28% collectibles rate by staying in IRA.
  </div>
  <div class="btn-row">
    <button class="btn btn-primary" onclick="recalc()">&#8635; Recalculate</button>
    <button class="btn btn-outline" onclick="resetAllocs()">Reset to Defaults</button>
  </div>
  <div class="disclaimer">All values persist via browser storage. Hover over any fund name to see the account placement rationale. Not financial advice.</div>
</div>

<!-- TAB 2: ACCOUNTS -->
<div class="tab-pane" id="tab-accounts">
  <div class="sec-head">Account Balances</div>
  <div class="info-box">Enter your current balance in each account. The DCA tab will distribute your budget across accounts proportionally, respecting tax placement rules.</div>
  <div class="accounts-grid">
    <div class="acct-card ira">
      <div class="acct-name">Traditional IRA</div>
      <div class="acct-field"><label>Current Balance ($)</label><input type="number" id="bal-ira" value="600000" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-field"><label>Target % of Portfolio</label><input type="number" id="pct-ira" value="54" min="0" max="100" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-tickers"><div class="tl">Holdings</div><div class="ticker-pills" id="tp-ira"></div></div>
    </div>
    <div class="acct-card roth">
      <div class="acct-name">Roth IRA</div>
      <div class="acct-field"><label>Current Balance ($)</label><input type="number" id="bal-roth" value="140000" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-field"><label>Target % of Portfolio</label><input type="number" id="pct-roth" value="13" min="0" max="100" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-tickers"><div class="tl">Holdings</div><div class="ticker-pills" id="tp-roth"></div></div>
    </div>
    <div class="acct-card brok">
      <div class="acct-name">Brokerage</div>
      <div class="acct-field"><label>Current Balance ($)</label><input type="number" id="bal-brok" value="320000" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-field"><label>Target % of Portfolio</label><input type="number" id="pct-brok" value="29" min="0" max="100" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-tickers"><div class="tl">Holdings</div><div class="ticker-pills" id="tp-brok"></div></div>
    </div>
    <div class="acct-card hsa">
      <div class="acct-name">HSA</div>
      <div class="acct-field"><label>Current Balance ($)</label><input type="number" id="bal-hsa" value="50000" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-field"><label>Target % of Portfolio</label><input type="number" id="pct-hsa" value="4" min="0" max="100" oninput="saveAccts();updateAcctSummary()"></div>
      <div class="acct-tickers"><div class="tl">Holdings</div><div class="ticker-pills" id="tp-hsa"></div></div>
    </div>
  </div>
  <div class="summary-row">
    <div class="sum-card"><div class="sc-label">Total Portfolio</div><div class="sc-val blue" id="as-total">$1,110,000</div></div>
    <div class="sum-card"><div class="sc-label">4% Income Target</div><div class="sc-val accent" id="as-target">$44,400</div></div>
    <div class="sum-card"><div class="sc-label">Tax-Deferred (IRA+HSA)</div><div class="sc-val" id="as-deferred">0%</div></div>
    <div class="sum-card"><div class="sc-label">Tax-Free (Roth)</div><div class="sc-val green" id="as-free">0%</div></div>
    <div class="sum-card"><div class="sc-label">Taxable (Brokerage)</div><div class="sc-val" id="as-taxable">0%</div></div>
  </div>
  <div class="rmd-card">
    <strong>RMD Notice:</strong> Required Minimum Distributions begin at age 73. On a $600K IRA the current RMD is approximately <strong>$22,600/year</strong> (IRS factor 26.5). This is ordinary income and may push you into a higher bracket. Consider Roth conversions in lower-income years to reduce future RMD burden.
  </div>
</div>

<!-- TAB 3: DCA PLAN -->
<div class="tab-pane" id="tab-dca">
  <div class="sec-head">DCA Plan<small>Dollar-Cost Averaging by Account &amp; Ticker</small></div>
  <div class="dca-controls">
    <div class="dc-head">DCA Settings</div>
    <div class="dc-field"><label>Signal (from Tool 1)</label>
      <select id="dc-signal" onchange="buildDCA();saveSettings()">
        <option value="green">Full DCA (100%)</option>
        <option value="yellow">Half DCA (50%)</option>
        <option value="red">Hold Cash (0%)</option>
      </select>
    </div>
    <div class="dc-field"><label>Monthly Budget ($)</label><input type="number" id="dc-budget" value="2000" min="0" step="100" oninput="buildDCA();saveSettings()"></div>
    <div class="dc-field"><label>Frequency</label>
      <select id="dc-freq" onchange="buildDCA();saveSettings()">
        <option value="monthly">Monthly</option><option value="biweekly">Bi-weekly</option><option value="weekly">Weekly</option>
      </select>
    </div>
    <div class="dc-field"><label>Priority</label>
      <select id="dc-priority" onchange="buildDCA();saveSettings()">
        <option value="income">Maximize Income</option><option value="balanced">Balanced</option><option value="growth">Maximize Growth</option>
      </select>
    </div>
  </div>
  <div id="dca-signal-banner" class="info-box">Select a signal above to begin.</div>
  <div class="tbl-wrap">
    <table class="dca-table">
      <thead><tr><th>Ticker</th><th>Account</th><th>Why This Account</th><th>Alloc%</th><th>DCA Amount</th><th>Priority</th></tr></thead>
      <tbody id="dca-body"></tbody>
    </table>
  </div>
  <div class="summary-row">
    <div class="sum-card"><div class="sc-label">Total This Period</div><div class="sc-val accent" id="dc-total">$0</div></div>
    <div class="sum-card"><div class="sc-label">Into IRA</div><div class="sc-val" id="dc-ira">$0</div></div>
    <div class="sum-card"><div class="sc-label">Into Roth</div><div class="sc-val green" id="dc-roth">$0</div></div>
    <div class="sum-card"><div class="sc-label">Into Brokerage</div><div class="sc-val" id="dc-brok">$0</div></div>
    <div class="sum-card"><div class="sc-label">Into HSA</div><div class="sc-val" id="dc-hsa">$0</div></div>
  </div>
  <div id="dca-warn" class="warn-box" style="display:none"></div>
</div>

<!-- TAB 4: PROJECTION -->
<div class="tab-pane" id="tab-projection">
  <div class="sec-head">12-Month Projection<small>Income vs. Total Return</small></div>
  <div class="proj-controls">
    <span class="proj-lbl">Scenario:</span>
    <button class="proj-btn active" onclick="setScenario('flat',this)">Flat 0%</button>
    <button class="proj-btn" onclick="setScenario('up',this)">Up +10%</button>
    <button class="proj-btn" onclick="setScenario('down',this)">Down -15%</button>
    <span class="proj-lbl" style="margin-left:.8rem">SS Cut:</span>
    <button class="proj-btn" id="ss-btn" onclick="toggleSS()">+20% SS Cut</button>
  </div>
  <div class="chart-wrap">
    <div class="chart-title">Portfolio Balance &amp; Cumulative Income<small id="chart-subtitle">Flat scenario</small></div>
    <canvas id="proj-canvas" height="300"></canvas>
    <div class="proj-legend">
      <div class="leg-item"><div class="leg-dot" style="background:#1e6b3a"></div>Total Return (balance)</div>
      <div class="leg-item"><div class="leg-dot" style="background:#9a7a1a"></div>Cumulative Income received</div>
      <div class="leg-item"><div class="leg-dot" style="background:rgba(139,26,26,.5)"></div>Balance with SS Cut</div>
    </div>
  </div>
  <div class="longevity-card">
    <div class="lon-item"><div class="lon-label">Portfolio Survives To</div><div class="lon-val" id="lon-age">-</div></div>
    <div class="lon-item"><div class="lon-label">Balance at Age 95</div><div class="lon-val" id="lon-95">-</div></div>
    <div class="lon-item"><div class="lon-label">Min Return Needed</div><div class="lon-val" id="lon-req">-</div></div>
    <div class="lon-item"><div class="lon-label">Income vs Target</div><div class="lon-val" id="lon-gap">-</div></div>
    <div class="lon-item"><div class="lon-label">SS Cut Annual Impact</div><div class="lon-val" id="lon-ss">-</div></div>
  </div>
  <div class="info-box" style="margin-top:1.1rem">
    <strong>Sequence of returns is your #1 risk.</strong> A Down -15% scenario in year 1 forces you to sell depressed assets to fund the $44K withdrawal. Your SGOV (T-bills) and JEPI income exist to prevent this &mdash; they fund withdrawals for years 1-3 without touching equities. That buffer is the difference between recovering and a permanent impairment.
  </div>
  <div class="disclaimer">Projections use simplified linear assumptions. Actual returns are non-linear and sequence-dependent. Not financial advice.</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const HOLDINGS=[
  {t:'SGOV',n:'iShares 0-3 Month Treasury',     cat:'T-Bills',        acct:'IRA',       it:'Ordinary Income',           y:5.1, er:0.09,a:10,why:'Ordinary income sheltered from annual tax in IRA. Cash-equivalent safety buffer.'},
  {t:'VTIP',n:'Vanguard Short-Term TIPS',        cat:'TIPS',           acct:'IRA',       it:'Ordinary + Inflation Adj',  y:4.2, er:0.04,a:8, why:'Inflation adjustments taxable annually - IRA shields this. Core 26-yr inflation hedge.'},
  {t:'BSV', n:'Vanguard Short-Term Bond',        cat:'Short Bond',     acct:'IRA',       it:'Ordinary Income',           y:4.6, er:0.04,a:10,why:'Steady ordinary income sheltered in IRA prevents annual tax drag on bond interest.'},
  {t:'SCHD',n:'Schwab US Dividend Equity',       cat:'Dividend Equity',acct:'Brokerage', it:'Qualified Dividends',       y:3.7, er:0.06,a:15,why:'Qualified dividends taxed at 0-15% in brokerage. No benefit to sheltering. Tax-loss harvesting available.'},
  {t:'JEPI',n:'JPMorgan Equity Premium Income',  cat:'Covered Call',   acct:'IRA',       it:'Ordinary Income (ELNs)',    y:7.4, er:0.35,a:10,why:'High ordinary income from equity-linked notes must stay in IRA to avoid top-bracket annual taxation.'},
  {t:'VTI', n:'Vanguard Total Stock Market',     cat:'US Equity',      acct:'Roth',      it:'Qualified Dividends',       y:1.4, er:0.03,a:18,why:'Long-term growth compounding completely tax-free in Roth over 26 years is the most powerful placement available.'},
  {t:'SPDW',n:'SPDR Portfolio Developed World',  cat:'Intl Developed', acct:'Brokerage', it:'Qualified Dividends',       y:3.2, er:0.04,a:8, why:'Foreign tax credit only available in taxable brokerage. Sheltering in IRA permanently loses this annual credit.'},
  {t:'IAU', n:'iShares Gold Trust',              cat:'Gold',           acct:'IRA',       it:'None (price return)',        y:0,   er:0.25,a:7, why:'Gold taxed at 28% collectibles rate if in brokerage. IRA avoids this. SS + inflation hedge position.'},
  {t:'XLE', n:'Energy Select Sector SPDR',       cat:'Energy',         acct:'Brokerage', it:'Qualified Dividends',       y:3.4, er:0.09,a:4, why:'Qualified dividends are tax-efficient in brokerage. Inflation hedge in taxable account.'},
  {t:'QQQI',n:'NEOS NASDAQ 100 High Income',     cat:'Covered Call',   acct:'IRA',       it:'60/40 Cap Gains (options)', y:14.0,er:0.68,a:5, why:'High income best sheltered in IRA. 60/40 options treatment helps but income level still warrants IRA placement.'},
  {t:'PFF', n:'iShares Preferred & Income Secs', cat:'Preferred Stock',acct:'IRA',       it:'Ordinary Income',           y:6.2, er:0.46,a:5, why:'Preferred dividends taxed as ordinary income. IRA is the correct home for this income type.'},
];
const ACCT_RATIONALE={
  'IRA':      'Tax-deferred: ordinary income not taxed annually',
  'Roth':     'Tax-free growth: best for long-term high-growth assets',
  'Brokerage':'Qualified divs at 0-15%; foreign tax credit preserved',
  'HSA':      'Triple tax advantage: healthcare or stealth IRA after 65',
};
let scenario='flat',ssCut=false,signal='green',projChart=null;
const SK={allocs:'pm_allocs',balances:'pm_balances',settings:'pm_settings',signal:'pm_signal'};
function ss(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}
function sl(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d;}catch(e){return d;}}
function saveAllocs(){ss(SK.allocs,HOLDINGS.map((_,i)=>{const e=document.getElementById('alloc-'+i);return e?parseFloat(e.value)||0:HOLDINGS[i].a;}));}
function loadAllocs(){const a=sl(SK.allocs,null);if(a)HOLDINGS.forEach((h,i)=>{if(a[i]!==undefined)h.a=a[i];});}
function saveAccts(){ss(SK.balances,{ira:+document.getElementById('bal-ira').value||0,roth:+document.getElementById('bal-roth').value||0,brok:+document.getElementById('bal-brok').value||0,hsa:+document.getElementById('bal-hsa').value||0,pIra:+document.getElementById('pct-ira').value||0,pRoth:+document.getElementById('pct-roth').value||0,pBrok:+document.getElementById('pct-brok').value||0,pHsa:+document.getElementById('pct-hsa').value||0});}
function loadAccts(){const b=sl(SK.balances,null);if(!b)return;['ira','roth','brok','hsa'].forEach(k=>{const e=document.getElementById('bal-'+k);if(e&&b[k]!==undefined)e.value=b[k];});['pIra','pRoth','pBrok','pHsa'].forEach((k,i)=>{const ids=['pct-ira','pct-roth','pct-brok','pct-hsa'];const e=document.getElementById(ids[i]);if(e&&b[k]!==undefined)e.value=b[k];});}
function saveSettings(){ss(SK.settings,{budget:document.getElementById('dc-budget').value,freq:document.getElementById('dc-freq').value,pri:document.getElementById('dc-priority').value,sig:document.getElementById('dc-signal').value});}
function loadSettings(){const s=sl(SK.settings,null);if(!s)return;if(s.budget)document.getElementById('dc-budget').value=s.budget;if(s.freq)document.getElementById('dc-freq').value=s.freq;if(s.pri)document.getElementById('dc-priority').value=s.pri;if(s.sig)document.getElementById('dc-signal').value=s.sig;}
function getPortfolio(){const ira=+document.getElementById('bal-ira').value||600000,roth=+document.getElementById('bal-roth').value||140000,brok=+document.getElementById('bal-brok').value||320000,hsa=+document.getElementById('bal-hsa').value||50000;return{ira,roth,brok,hsa,total:ira+roth+brok+hsa};}
function fmt(n){if(Math.abs(n)>=1e6)return'$'+(n/1e6).toFixed(2)+'M';return'$'+Math.round(n).toLocaleString();}
function fmtP(n){return n.toFixed(2)+'%';}
function showTab(id,btn){
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
  if(id==='dca')buildDCA();
  if(id==='projection')buildProjection();
  if(id==='accounts')updateAcctSummary();
}
function setSignal(s){
  signal=s;
  ['green','yellow','red'].forEach(c=>document.getElementById('sig-'+c).classList.remove('active'));
  document.getElementById('sig-'+s).classList.add('active');
  document.getElementById('dc-signal').value=s;
  const notes={green:'Full DCA active - deploy full monthly budget across all positions per allocation weights.',yellow:'Half DCA - deploy 50% of budget, hold remainder in money market until signal clears.',red:'Hold Cash - no DCA this period. Protect income reserve. Revisit next week.'};
  document.getElementById('signal-note').textContent=notes[s];
  ss(SK.signal,s);
  buildDCA();
}
function renderHoldings(){
  const pf=getPortfolio();
  const body=document.getElementById('htable-body');
  body.innerHTML='';
  let ta=0,ti=0,wY=0,wER=0;
  HOLDINGS.forEach((h,i)=>{
    ta+=h.a;
    const d=pf.total*h.a/100,inc=d*h.y/100;
    ti+=inc;wY+=h.y*h.a;wER+=h.er*h.a;
    const tc=h.acct==='IRA'?'tag-ira':h.acct==='Roth'?'tag-roth':h.acct==='Brokerage'?'tag-brok':'tag-hsa';
    const tr=document.createElement('tr');
    tr.innerHTML='<td class="tc">'+h.t+'</td><td class="tn" title="'+h.why+'">'+h.n+'</td><td style="font-size:.74rem;color:var(--muted)">'+h.cat+'</td><td><span class="tag '+tc+'">'+h.acct+'</span></td><td style="font-size:.7rem;color:var(--muted)">'+h.it+'</td><td class="right yld">'+(h.y>0?fmtP(h.y):'--')+'</td><td class="right er">'+fmtP(h.er)+'</td><td class="right"><input class="alloc-inp" id="alloc-'+i+'" type="number" value="'+h.a+'" min="0" max="100" step="0.5" oninput="HOLDINGS['+i+'].a=parseFloat(this.value)||0;recalc()"></td><td class="right mono" style="font-size:.78rem">'+fmt(d)+'</td><td class="right mono" style="font-size:.78rem;color:var(--green)">'+(h.y>0?fmt(inc):'--')+'</td>';
    body.appendChild(tr);
  });
  const fill=document.getElementById('alloc-bar-fill');
  fill.style.width=Math.min(ta,100)+'%';
  fill.className='alloc-bar-fill'+(ta>100?' over':'');
  document.getElementById('alloc-pct-text').textContent=ta.toFixed(1)+' / 100%';
  document.getElementById('alloc-label').textContent='Total: '+ta.toFixed(1)+'%';
  const need=pf.total*0.04,cov=ti/need*100,bY=wY/Math.max(ta,1),bER=wER/Math.max(ta,1);
  document.getElementById('sv-port').textContent=fmt(pf.total);
  const svi=document.getElementById('sv-income');svi.textContent=fmt(ti);svi.className='sc-val '+(ti>=need?'green':'yellow');
  document.getElementById('sv-target').textContent=fmt(need);
  const svc=document.getElementById('sv-cov');svc.textContent=cov.toFixed(0)+'%';svc.className='sc-val '+(cov>=100?'green':cov>=80?'yellow':'red');
  const svy=document.getElementById('sv-yield');svy.textContent=fmtP(bY);svy.className='sc-val '+(bY>=4?'green':'yellow');
  document.getElementById('sv-er').textContent=fmtP(bER);
}
function recalc(){renderHoldings();saveAllocs();}
function resetAllocs(){[10,8,10,15,10,18,8,7,4,5,5].forEach((v,i)=>HOLDINGS[i].a=v);renderHoldings();saveAllocs();}
function updateAcctSummary(){
  const pf=getPortfolio();
  document.getElementById('as-total').textContent=fmt(pf.total);
  document.getElementById('as-target').textContent=fmt(pf.total*0.04);
  document.getElementById('as-deferred').textContent=((pf.ira+pf.hsa)/pf.total*100).toFixed(0)+'%';
  document.getElementById('as-free').textContent=(pf.roth/pf.total*100).toFixed(0)+'%';
  document.getElementById('as-taxable').textContent=(pf.brok/pf.total*100).toFixed(0)+'%';
  const g={IRA:[],Roth:[],Brokerage:[],HSA:[]};
  HOLDINGS.forEach(h=>{if(g[h.acct])g[h.acct].push(h.t);});
  if(!g.HSA.length)g.HSA=['SGOV','BSV'];
  [['IRA','tp-ira'],['Roth','tp-roth'],['Brokerage','tp-brok'],['HSA','tp-hsa']].forEach(([a,id])=>{
    const el=document.getElementById(id);
    if(el)el.innerHTML=(g[a]||[]).map(t=>'<span class="ticker-pill">'+t+'</span>').join('');
  });
}
function buildDCA(){
  const sig=document.getElementById('dc-signal').value;
  const budget=parseFloat(document.getElementById('dc-budget').value)||2000;
  const freq=document.getElementById('dc-freq').value;
  const pri=document.getElementById('dc-priority').value;
  const pb=freq==='weekly'?budget/4.33:freq==='biweekly'?budget/2:budget;
  const mult=sig==='green'?1:sig==='yellow'?.5:0;
  const dep=pb*mult;
  const banners={green:'<strong>Full DCA active.</strong> Markets are favorable. Deploy full budget proportionally across all positions per allocation weights.',yellow:'<strong>Half DCA.</strong> Elevated uncertainty - deploying 50% of budget. Remaining cash holds in money market until signal clears.',red:'<strong>Hold Cash - No DCA this period.</strong> Market conditions unfavorable. Protect your income reserve. Revisit next week after checking Market Signal.'};
  const banner=document.getElementById('dca-signal-banner');
  banner.innerHTML=banners[sig];banner.className=sig==='red'?'warn-box':'info-box';
  let sorted=[...HOLDINGS.map((h,i)=>({...h,i}))];
  if(pri==='income')sorted.sort((a,b)=>b.y-a.y);
  if(pri==='growth')sorted.sort((a,b)=>(b.a*(1-b.y/100))-(a.a*(1-a.y/100)));
  const ta=HOLDINGS.reduce((s,h)=>s+h.a,0)||100;
  const body=document.getElementById('dca-body');body.innerHTML='';
  const tots={IRA:0,Roth:0,Brokerage:0,HSA:0};
  sorted.forEach((h,rank)=>{
    const share=h.a/ta,amt=dep*share;
    tots[h.acct]=(tots[h.acct]||0)+amt;
    const tc=h.acct==='IRA'?'tag-ira':h.acct==='Roth'?'tag-roth':h.acct==='Brokerage'?'tag-brok':'tag-hsa';
    const pc=rank<4?'pri-green':rank<8?'pri-yellow':'pri-red';
    const pl=rank<4?'High':rank<8?'Medium':'Lower';
    const tr=document.createElement('tr');
    tr.innerHTML='<td class="tc">'+h.t+'</td><td><span class="tag '+tc+'">'+h.acct+'</span></td><td class="dca-rat">'+ACCT_RATIONALE[h.acct]+'</td><td class="mono" style="font-size:.76rem;text-align:right">'+h.a+'%</td><td class="dca-amt" style="text-align:right">'+(sig==='red'?'$0':fmt(amt))+'</td><td><span class="pri-badge '+pc+'">'+pl+'</span></td>';
    body.appendChild(tr);
  });
  document.getElementById('dc-total').textContent=fmt(dep);
  document.getElementById('dc-ira').textContent=fmt(tots.IRA||0);
  document.getElementById('dc-roth').textContent=fmt(tots.Roth||0);
  document.getElementById('dc-brok').textContent=fmt(tots.Brokerage||0);
  document.getElementById('dc-hsa').textContent=fmt(tots.HSA||0);
  const warn=document.getElementById('dca-warn');
  if(sig==='red'){warn.style.display='block';warn.innerHTML='<strong>No DCA this period.</strong> Check whether any positions have drifted more than 3% from targets and need trimming. Return to Market Signal to monitor for green light.';}
  else warn.style.display='none';
}
function setScenario(s,btn){
  scenario=s;
  document.querySelectorAll('.proj-btn:not(#ss-btn)').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');buildProjection();
}
function toggleSS(){
  ssCut=!ssCut;
  const btn=document.getElementById('ss-btn');
  btn.classList.toggle('active',ssCut);
  btn.textContent=ssCut?'SS Cut ON':'+20% SS Cut';
  buildProjection();
}
function buildProjection(){
  const pf=getPortfolio(),total=pf.total;
  const ta=HOLDINGS.reduce((s,h)=>s+h.a,0)||100;
  const blendY=HOLDINGS.reduce((s,h)=>s+h.y*h.a,0)/ta/100;
  const aw=total*0.04,ssE=ssCut?aw*0.2:0;
  const gr={flat:0,up:.10,down:-.15}[scenario];
  const labels=['Now',...Array.from({length:12},(_,i)=>'Mo '+(i+1))];
  let bal=total,balSS=total,ci=0,ciSS=0;
  const bd=[],id=[],bsd=[],isd=[];
  for(let m=0;m<=12;m++){
    bd.push(+bal.toFixed(0));id.push(+ci.toFixed(0));bsd.push(+balSS.toFixed(0));isd.push(+ciSS.toFixed(0));
    if(m<12){
      const mg=(1+gr)**(1/12)-1,mi=bal*blendY/12,mw=(aw+ssE)/12;
      ci+=mi;bal=bal*(1+mg)-mw;
      const miSS=balSS*blendY/12,mwSS=(aw+aw*.2)/12;
      ciSS+=miSS;balSS=balSS*(1+mg)-mwSS;
    }
  }
  const lr=Math.max(gr,.04);
  let lb=total,la=69;
  for(let y=0;y<50;y++){lb=lb*(1+lr)-aw;if(lb<=0){la=69+y;break;}if(y===49)la=119;}
  let b95=total;for(let y=0;y<26;y++)b95=b95*(1+lr)-aw;
  const ai=total*blendY,gap=ai-aw;
  const lonAge=document.getElementById('lon-age');lonAge.textContent=la>=119?'119+ yrs':'Age '+la;lonAge.className='lon-val '+(la>=95?'good':la>=85?'warn':'bad');
  const lon95=document.getElementById('lon-95');lon95.textContent=fmt(b95);lon95.className='lon-val '+(b95>0?'good':'bad');
  document.getElementById('lon-req').textContent=fmtP(aw/total*100);
  const lg=document.getElementById('lon-gap');lg.textContent=(gap>=0?'+':'')+fmt(gap)+'/yr';lg.className='lon-val '+(gap>=0?'good':'bad');
  const ls=document.getElementById('lon-ss');ls.textContent=ssCut?'-'+fmt(ssE)+'/yr':'Not modeled';ls.className='lon-val '+(ssCut?'bad':'good');
  document.getElementById('chart-subtitle').textContent=(scenario==='flat'?'Flat 0%':scenario==='up'?'Up +10%':'Down -15%')+' scenario'+(ssCut?' + SS Cut 20%':'');
  if(projChart)projChart.destroy();
  const ctx=document.getElementById('proj-canvas').getContext('2d');
  const ds=[
    {label:'Portfolio Balance',data:bd,borderColor:'#1e6b3a',backgroundColor:'rgba(30,107,58,.06)',fill:true,tension:.35,pointRadius:3,pointHoverRadius:6,yAxisID:'y'},
    {label:'Cumulative Income',data:id,borderColor:'#9a7a1a',fill:false,tension:.35,pointRadius:3,pointHoverRadius:6,borderDash:[6,3],yAxisID:'y'},
  ];
  if(ssCut)ds.push({label:'Balance (SS Cut)',data:bsd,borderColor:'rgba(139,26,26,.55)',fill:false,tension:.35,pointRadius:2,borderDash:[3,3],yAxisID:'y'});
  projChart=new Chart(ctx,{type:'line',data:{labels,datasets:ds},options:{responsive:true,interaction:{mode:'index',intersect:false},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.dataset.label+': '+fmt(c.raw)}}},scales:{y:{ticks:{callback:v=>fmt(v),color:'#7a7468',font:{family:"'IBM Plex Mono',monospace",size:10}},grid:{color:'#e4e0d5'}},x:{ticks:{color:'#7a7468',font:{family:"'IBM Plex Mono',monospace",size:10}},grid:{display:false}}}}});
}
function init(){
  loadAllocs();loadAccts();loadSettings();
  const s=sl(SK.signal,'green');setSignal(s);
  renderHoldings();updateAcctSummary();
}
init();
</script>
</body>
</html>
